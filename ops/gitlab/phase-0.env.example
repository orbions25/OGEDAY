# OGEDAY GitLab Phase 0 environment template.
# Copy this file outside the repository if you need local overrides.
# Do not add secrets, tokens, private keys, or passwords to this file.

GITLAB_EXTERNAL_URL=https://gitlab.ogedays.com
GITLAB_HOST=gitlab.ogedays.com
ROOT_DOMAIN=ogedays.com

# Fill after the target GitLab server is selected.
GITLAB_SERVER_IPV4=
GITLAB_SERVER_IPV6=

# Fill after the GitLab project is imported.
GITLAB_URL=https://gitlab.ogedays.com
GITLAB_PROJECT_ID=

# Use only in your shell/session. Never commit real token values.
GITLAB_TOKEN=
RUNNER_AUTH_TOKEN=

